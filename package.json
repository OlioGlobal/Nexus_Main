{
  "name": "nexus",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=4096\" next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "seed:blogs": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed-blogs.ts",
    "seed:blog-images": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed-blog-images.ts",
    "seed:jobs": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed-jobs.ts",
    "seed:case-studies": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed-case-studies.ts",
    "seed:case-study-images": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed-case-study-images.ts",
    "seed:audience": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed-audience.ts",
    "seed:impact-stories": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed-impact-stories.ts",
    "seed:faq-cta": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed-faq-cta.ts",
    "seed:industries": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed-industries.ts",
    "migrate:case-studies": "cross-env NODE_OPTIONS=--no-deprecation tsx src/migrate-case-studies.ts",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@payloadcms/db-mongodb": "3.80.0",
    "@payloadcms/email-nodemailer": "^3.80.0",
    "@payloadcms/next": "3.80.0",
    "@payloadcms/richtext-lexical": "3.80.0",
    "@payloadcms/ui": "3.80.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "graphql": "^16.8.1",
    "isomorphic-dompurify": "^3.7.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "nodemailer": "^8.0.3",
    "payload": "3.80.0",
    "payload-cloudinary": "^2.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "dotenv": "^17.3.1",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.0",
    "jsdom": "28.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
